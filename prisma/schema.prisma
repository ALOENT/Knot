generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String    @unique
  displayName     String?
  password        String
  bio             String?
  profilePic      String?
  banner          String?
  isOnline        Boolean   @default(false)
  lastSeen        DateTime?
  role            Role      @default(USER)
  // System-level verification. UI should display badge only if isVerified AND privacySettings.allowDisplayVerifiedBadge are true.
  isVerified      Boolean   @default(false)
  isBanned        Boolean   @default(false)
  privacySettings Json?     @default("{\"allowDisplayVerifiedBadge\": true, \"showTyping\": true}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Messages
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  // Reports
  reportsSubmitted Report[] @relation("Reporter")
  reportsReceived  Report[] @relation("ReportedUser")

  // Friendships
  friendshipsInitiated Friendship[] @relation("UserFriendships")
  friendshipsReceived  Friendship[] @relation("FriendFriendships")

  // Blocks
  blockedUsers Block[] @relation("Blocker")
  blockedBy    Block[] @relation("BlockedUser")

  // Warnings
  warnings Warning[] @relation("UserWarnings")
}

model Message {
  id         String   @id @default(uuid())
  content    String?
  fileUrl    String? // For images, docs
  fileName   String? // Original filename for UI / downloads (optional for legacy rows)
  attachmentBytes Int? // File size in bytes (set on upload)
  attachmentPages Int? // PDF page count when known; null for non-PDF
  senderId   String
  receiverId String
  replyToId  String?
  isDeleted  Boolean  @default(false) // Soft deletion for admin audit
  status     MessageStatus @default(SENT)
  timestamp  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  replyTo  Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies  Message[] @relation("MessageReplies")

  @@index([senderId, receiverId])
  @@index([receiverId])
  @@index([senderId, receiverId, status])
  @@index([timestamp])
}

enum ReportStatus {
  PENDING
  RESOLVED
}

model Report {
  id              String       @id @default(uuid())
  reporterId      String
  reportedUserId  String
  reason          String
  contextMessages Json // Snapshot of last 15 messages for review
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now())

  reporter     User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String           @id @default(uuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Warning {
  id          String   @id @default(uuid())
  userId      String
  message     String
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation("UserWarnings", fields: [userId], references: [id], onDelete: Cascade)
}
